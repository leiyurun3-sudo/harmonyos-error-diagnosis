/** P0 error codes defined by detailed design section 11.2. */
export enum ErrorCode {
  VAL_INPUT_EMPTY = 'VAL_INPUT_EMPTY',
  VAL_INPUT_TOO_LONG = 'VAL_INPUT_TOO_LONG',
  VAL_JSON_TOO_LARGE = 'VAL_JSON_TOO_LARGE',
  VAL_FORMAT_INVALID = 'VAL_FORMAT_INVALID',
  PICKER_CANCELLED = 'PICKER_CANCELLED',
  IMAGE_READ_FAILED = 'IMAGE_READ_FAILED',
  OCR_UNAVAILABLE = 'OCR_UNAVAILABLE',
  OCR_NO_TEXT = 'OCR_NO_TEXT',
  OCR_TIMEOUT = 'OCR_TIMEOUT',
  OCR_FAILED = 'OCR_FAILED',
  RULE_RESOURCE_FAILED = 'RULE_RESOURCE_FAILED',
  DIAGNOSIS_FAILED = 'DIAGNOSIS_FAILED',
  REPORT_NOT_FOUND = 'REPORT_NOT_FOUND',
  DATA_PARSE_FAILED = 'DATA_PARSE_FAILED',
  STORAGE_READ_FAILED = 'STORAGE_READ_FAILED',
  STORAGE_WRITE_FAILED = 'STORAGE_WRITE_FAILED',
  STORAGE_DELETE_FAILED = 'STORAGE_DELETE_FAILED',
  STORAGE_MIGRATION_FAILED = 'STORAGE_MIGRATION_FAILED',
  SETTINGS_READ_FAILED = 'SETTINGS_READ_FAILED',
  SETTINGS_WRITE_FAILED = 'SETTINGS_WRITE_FAILED',
  ROUTE_PARAM_INVALID = 'ROUTE_PARAM_INVALID',
  UNKNOWN_ERROR = 'UNKNOWN_ERROR'
}

/** Returns a new collection so callers cannot mutate the shared error catalog. */
export function getP0ErrorCodes(): Array<ErrorCode> {
  return [
    ErrorCode.VAL_INPUT_EMPTY,
    ErrorCode.VAL_INPUT_TOO_LONG,
    ErrorCode.VAL_JSON_TOO_LARGE,
    ErrorCode.VAL_FORMAT_INVALID,
    ErrorCode.PICKER_CANCELLED,
    ErrorCode.IMAGE_READ_FAILED,
    ErrorCode.OCR_UNAVAILABLE,
    ErrorCode.OCR_NO_TEXT,
    ErrorCode.OCR_TIMEOUT,
    ErrorCode.OCR_FAILED,
    ErrorCode.RULE_RESOURCE_FAILED,
    ErrorCode.DIAGNOSIS_FAILED,
    ErrorCode.REPORT_NOT_FOUND,
    ErrorCode.DATA_PARSE_FAILED,
    ErrorCode.STORAGE_READ_FAILED,
    ErrorCode.STORAGE_WRITE_FAILED,
    ErrorCode.STORAGE_DELETE_FAILED,
    ErrorCode.STORAGE_MIGRATION_FAILED,
    ErrorCode.SETTINGS_READ_FAILED,
    ErrorCode.SETTINGS_WRITE_FAILED,
    ErrorCode.ROUTE_PARAM_INVALID,
    ErrorCode.UNKNOWN_ERROR
  ];
}
